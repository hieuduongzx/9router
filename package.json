{
  "name": "9router",
  "version": "0.4.59",
  "description": "9Router - Universal AI Gateway for Code Tools",
  "private": true,
  "bin": {
    "9router": "cli.js"
  },
  "files": [
    "cli.js",
    "app/",
    "hooks/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "next dev --webpack --port 20129",
    "build": "NODE_ENV=production next build --webpack",
    "start": "NODE_ENV=production next start",
    "build:cli": "node scripts/prepublish.mjs",
    "prepublishOnly": "npm run build:cli",
    "postinstall": "node hooks/postinstall.js",
    "dev:bun": "bun --bun next dev --webpack --port 20129",
    "build:bun": "NODE_ENV=production bun --bun next build --webpack",
    "start:bun": "NODE_ENV=production bun ./.next/standalone/server.js",
    "docker:build": "docker build -t amritazx/9router:latest .",
    "docker:push": "docker push amritazx/9router:latest",
    "docker:publish": "docker build -t amritazx/9router:latest . && docker push amritazx/9router:latest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "router",
    "proxy",
    "openai",
    "claude",
    "gemini",
    "fallback",
    "cursor",
    "cline",
    "codex",
    "9router"
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-accordion": "^1.2.12",
